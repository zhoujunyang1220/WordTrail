import React, { useState, useEffect } from "react";
import { 
  Sparkles, Plus, BookOpen, Clock, Lightbulb, CheckCircle2, ChevronDown, ChevronUp,
  Volume2, Search, Trash2, Calendar, Sun, Moon, Languages, Layers, AlertCircle,
  FileText, ArrowRight, Star, ExternalLink, HelpCircle, Save, Check, X
} from "lucide-react";
import { Word, Notebook, STAGE_LABELS, STAGE_LABELS_EN, EBBINGHAUS_INTERVALS } from "./types";
import { 
  getWords, saveWords, getNotebooks, saveNotebooks, createNotebook, deleteWord, registerReviewResult, updateWord 
} from "./lib/storage";
import AddWordModal from "./components/AddWordModal";
import TextImportScanner from "./components/TextImportScanner";

export default function App() {
  // State for raw lists
  const [words, setWords] = useState<Word[]>([]);
  const [notebooks, setNotebooks] = useState<Notebook[]>([]);
  const [activeNotebook, setActiveNotebook] = useState<string>("all");
  const [stageFilter, setStageFilter] = useState<string>("all");
  const [searchQuery, setSearchQuery] = useState("");

  // UI state controls
  const [isAddOpen, setIsAddOpen] = useState(false);
  const [isScannerOpen, setIsScannerOpen] = useState(false);
  const [expandedWordId, setExpandedWordId] = useState<string | null>(null);

  // Theme & Language Settings (persist inside localStorage)
  const [darkMode, setDarkMode] = useState<boolean>(() => {
    if (typeof window !== "undefined") {
      return localStorage.getItem("theme") === "dark" || false;
    }
    return false;
  });
  
  const [lang, setLang] = useState<"zh" | "en">(() => {
    if (typeof window !== "undefined") {
      return (localStorage.getItem("lang") as "zh" | "en") || "zh";
    }
    return "zh";
  });

  // Custom Notebook creator popup
  const [showNotebookCreator, setShowNotebookCreator] = useState(false);
  const [newNbName, setNewNbName] = useState("");
  const [newNbDesc, setNewNbDesc] = useState("");

  // Ebbinghaus active review card deck state
  const [reviewMode, setReviewMode] = useState<boolean>(false);
  const [isGeneralPractice, setIsGeneralPractice] = useState<boolean>(false); // review all if true
  const [currentReviewIndex, setCurrentReviewIndex] = useState<number>(0);
  const [answerRevealed, setAnswerRevealed] = useState<boolean>(false);

  // Spelling dictation mode states
  const [reviewType, setReviewType] = useState<"card" | "spelling">("card");
  const [spellingInput, setSpellingInput] = useState("");
  const [spellingChecked, setSpellingChecked] = useState(false);
  const [spellingResult, setSpellingResult] = useState<"correct" | "incorrect" | null>(null);

  // Clear spelling state on word switch
  useEffect(() => {
    setSpellingInput("");
    setSpellingChecked(false);
    setSpellingResult(null);
  }, [currentReviewIndex, reviewMode, reviewType]);

  // Fetch initial data
  useEffect(() => {
    setWords(getWords());
    setNotebooks(getNotebooks());
  }, []);

  // Update theme tag on parent container
  useEffect(() => {
    if (darkMode) {
      document.documentElement.classList.add("dark");
      localStorage.setItem("theme", "dark");
    } else {
      document.documentElement.classList.remove("dark");
      localStorage.setItem("theme", "light");
    }
  }, [darkMode]);

  // Update language tag
  useEffect(() => {
    localStorage.setItem("lang", lang);
  }, [lang]);

  // Utility translations dictionary
  const T = {
    brandName: lang === "zh" ? "词迹" : "WordTrail",
    tagline: lang === "zh" ? "用艾宾浩斯遗忘曲线，科学构建您的主动词汇库" : "Build your active English expression bank via Ebbinghaus repetition logic",
    
    // Theme triggers
    themeLight: lang === "zh" ? "浅色" : "Light",
    themeDark: lang === "zh" ? "深色" : "Dark",
    langZh: lang === "zh" ? "中文" : "Chinese",
    langEn: lang === "zh" ? "英文" : "English",

    // Action buttons
    actionAdd: lang === "zh" ? "手动录字 / 单词详解" : "Manual / Word Capture",
    actionScan: lang === "zh" ? "批量扫盲文章生词" : "Context Extraction Scan",

    // Metrics Row
    statDue: lang === "zh" ? "到期复习" : "Due now",
    statDueSub: lang === "zh" ? "需立即自评巩固" : "Ready to check",
    statTotal: lang === "zh" ? "词汇总量" : "Total Words",
    statTotalSub: lang === "zh" ? "自主阅读积累" : "Sourced active words",
    statMastery: lang === "zh" ? "已掌握词" : "Mastered",
    statMasterySub: lang === "zh" ? "Stage 7 & 8 阶段" : "Retained high mastery",
    statNotebooks: lang === "zh" ? "分类词本" : "Notebooks",
    statNotebooksSub: lang === "zh" ? "专属主题归纳" : "Tailored categories",

    // Review Deck
    deckHeader: lang === "zh" ? "🔬 艾宾浩斯遗忘曲线智能巩固" : "🔬 Ebbinghaus Intelligent Review Deck",
    deckSub: lang === "zh" 
      ? "根据艾宾浩斯遗忘临界点，自动挑选目前到期应该复习的生词。" 
      : "Selected candidates currently at critical forgetting points according to Ebbinghaus.",
    deckEmptyAll: lang === "zh" ? "恭喜你！所有艾宾浩斯复习任务已全部清空。👏" : "Incredible! All Ebbinghaus review lists are fully clear. 👏",
    deckEmptySub: lang === "zh" 
      ? "当前没有到期的生词。保持这个节奏！你可以录入新单词，或者点击下方进行通识随机练习。" 
      : "There are no due words left. Keep it up! Feel free to scan raw files, add new phrases or review current bank.",
    btnGeneralPractice: lang === "zh" ? "通识巩固：复习生词库全集" : "General Study: Practice All Stored Words",
    btnStopGeneral: lang === "zh" ? "结束通识复习" : "Quit General Review",
    btnReveal: lang === "zh" ? "揭开卡片 / 念出发音" : "Reveal Content / Pronounce",
    btnGotIt: lang === "zh" ? "我记住了 (进入下一阶段)" : "Got It (Next Stage)",
    btnForgot: lang === "zh" ? "我记错了 (艾宾浩斯重排)" : "Forgot It (Penalty Redo)",
    nextInLine: (num: number) => lang === "zh" ? `剩余待复习: ${num} 词` : `Words remaining: ${num}`,
    reviewRound: lang === "zh" ? "生词学习轮" : "Vocabulary Session",

    // Catalog & filter
    catalogTitle: lang === "zh" ? "📓 单词档案馆" : "📓 Word Archive",
    searchPlacer: lang === "zh" ? "搜索已记录英文词、中英文释义或上下文例句..." : "Search registered words, phrases, meanings or contextual sentences...",
    filterAllBooks: lang === "zh" ? "所有词本" : "All Notebooks",
    filterAllStages: lang === "zh" ? "所有艾宾浩斯阶段" : "All Stages",
    noWordsCatalog: lang === "zh" ? "您目前的检索没有匹配到任何生词卡片。" : "No vocabulary cards found in this filter.",
    addFirstWordBtn: lang === "zh" ? "立即记录你的第一个生词" : "Add Your First Active Word",
    
    // Details
    wordPhonetic: lang === "zh" ? "国际音标 (IPA)" : "IPA Phonetics",
    wordChinese: lang === "zh" ? "中文释意" : "Chinese Definition",
    wordEnglish: lang === "zh" ? "英文释义" : "English Definition",
    wordRoot: lang === "zh" ? "科学词根词缀剖析" : "Scientific Etymology & Prefix",
    wordMemory: lang === "zh" ? "记忆挂钩与趣味谐音" : "Memory Hook & Association",
    wordPhrases: lang === "zh" ? "极高频惯用搭配" : "Common High-frequency Phrases",
    wordExample: lang === "zh" ? "英汉学习例句" : "Example Sentences",
    wordNotes: lang === "zh" ? "点拨便签 / 备注" : "Personal Study Notes",
    wordStageLabel: lang === "zh" ? "艾宾浩斯记忆阶段" : "Ebbinghaus Memory Stage",
    wordNextReview: lang === "zh" ? "下次复习时间" : "Next Spaced Review",
    wordNextReviewDue: lang === "zh" ? "当前到期待复习" : "Due now",
    wordReviewHistory: lang === "zh" ? "复习互动历史" : "Historical Reviews",
    histCorrect: lang === "zh" ? "正确记忆" : "Correct Core",
    histForgot: lang === "zh" ? "模糊/遗忘" : "Forgot/Blurry",

    // Spelling translations
    practiceTypeCard: lang === "zh" ? "卡片记忆" : "Flashcard Review",
    practiceTypeSpelling: lang === "zh" ? "拼写默写" : "Spelling Dictation",
    spellingInputPlacer: lang === "zh" ? "输入该英文单词的拼写..." : "Type english spelling...",
    btnCheckSpelling: lang === "zh" ? "核对拼写" : "Validate Spell",
    spellingCorrectBadge: lang === "zh" ? "🎉 恭喜！拼写完全一致！" : "🎉 Excellent! Spelling is 150% correct!",
    spellingIncorrectBadge: lang === "zh" ? "❌ 拼写有误，再接再厉！" : "❌ Incorrect, please look at standard form!",
    spellingExpectedLabel: lang === "zh" ? "标准拼写：" : "Correct Spelling: ",
    spellingYourLabel: lang === "zh" ? "你的输入：" : "Your input: ",
    btnRetrySpelling: lang === "zh" ? "重新拼写" : "Retry Spelling",
    spellingHintLabel: lang === "zh" ? "首尾提示：" : "First & Last letters: ",

    // Notebook list sidebar
    booksTitle: lang === "zh" ? "🏷️ 词本管理" : "🏷️ Classified Notebooks",
    btnNewNotebook: lang === "zh" ? "新建生词本" : "+ Create Notebook",
    createNbTitle: lang === "zh" ? "建立新分类生词本" : "Create New Dedicated Notebook",
    createNbName: lang === "zh" ? "生词本名称" : "Notebook Name",
    createNbDesc: lang === "zh" ? "简短描述" : "Short Description",
    btnSaveNb: lang === "zh" ? "确认新建" : "Create Now",
    btnCancel: lang === "zh" ? "取消" : "Cancel",
    
    // Quick tip instructions (Simpler layout)
    instructionBoxTitle: lang === "zh" ? "背单词新主张 —— 什么是“主动词汇积累”？" : "A Smarter Method: What is 'Active Vocabulary Building'?",
    instruction1: lang === "zh" ? "拒绝死背词汇书词表。市面常规背单词依靠被动的词汇书，效果甚微。" : "Forget passive, boring vocabulary book lists. Those words lack contextual hooks.",
    instruction2: lang === "zh" ? "在阅读论文、浏览推特或观看视频时，复制粘贴遇到的困难段落，或者直接录入当时让你困惑的生词。" : "Paste foreign texts, academic paragraphs or movies scripts. Enter individual word queries anytime.",
    instruction3: lang === "zh" ? "通过艾宾浩斯遗忘规律，在到期时智能高亮，通过科学间隔重复（5分、30分、12小时、1天、2天等）稳牢变成自己的主动口语/写作词汇！" : "Our Ebbinghaus engine flags words in scientific intervals (5m, 30m, 12h, 1d, 2d, 4d, 7d, 15d). Systematically converting them into active speech components!"
  };

  // Synchronize localStorage mutations dynamically
  const reloadWords = () => {
    setWords(getWords());
  };

  const handleWordDeleted = (id: string) => {
    deleteWord(id);
    reloadWords();
    setExpandedWordId(null);
  };

  // Filter conditions
  const filteredWords = words.filter((item) => {
    const matchNotebook = activeNotebook === "all" || item.notebookId === activeNotebook;
    
    let matchStage = true;
    if (stageFilter !== "all") {
      if (stageFilter === "due") {
        matchStage = item.nextReviewAt <= Date.now();
      } else if (stageFilter === "master") {
        matchStage = item.stage >= 7;
      } else if (stageFilter === "learning") {
        matchStage = item.stage > 0 && item.stage < 7;
      } else if (stageFilter === "new") {
        matchStage = item.stage === 0;
      } else {
        const targetStage = parseInt(stageFilter, 10);
        if (!isNaN(targetStage)) {
          matchStage = item.stage === targetStage;
        }
      }
    }

    const matchSearch = searchQuery.trim() === "" || 
      item.word.toLowerCase().includes(searchQuery.toLowerCase()) ||
      item.chineseDefinition.toLowerCase().includes(searchQuery.toLowerCase()) ||
      item.englishDefinition.toLowerCase().includes(searchQuery.toLowerCase()) ||
      (item.notes && item.notes.toLowerCase().includes(searchQuery.toLowerCase())) ||
      (item.sentences && item.sentences.some((s) => s.en.toLowerCase().includes(searchQuery.toLowerCase()) || s.zh.toLowerCase().includes(searchQuery.toLowerCase())));

    return matchNotebook && matchStage && matchSearch;
  });

  // Calculate stats
  const dueWords = words.filter((item) => item.nextReviewAt <= Date.now());
  const masteryWords = words.filter((item) => item.stage >= 7);
  const totalCount = words.length;

  const stageCounts = Array(9).fill(0);
  words.forEach((w) => {
    if (w.stage >= 0 && w.stage <= 8) {
      stageCounts[w.stage]++;
    }
  });

  const handleCreateNotebook = (e: React.FormEvent) => {
    e.preventDefault();
    if (!newNbName.trim()) return;
    createNotebook(newNbName.trim(), newNbDesc.trim());
    setNotebooks(getNotebooks());
    setNewNbName("");
    setNewNbDesc("");
    setShowNotebookCreator(false);
  };

  // Ebbinghaus rating review mechanics
  const activeReviewQueue = isGeneralPractice ? words : dueWords;
  const currentReviewWord = activeReviewQueue[currentReviewIndex];

  const handleRateReview = (result: "correct" | "incorrect") => {
    if (!currentReviewWord) return;
    
    // Register metric outcomes to localStorage
    const updated = registerReviewResult(currentReviewWord.id, result);
    reloadWords();

    setAnswerRevealed(false);
    
    if (currentReviewIndex + 1 >= activeReviewQueue.length) {
      // Completed current queue round
      setReviewMode(false);
      setIsGeneralPractice(false);
      setCurrentReviewIndex(0);
    } else {
      setCurrentReviewIndex(currentReviewIndex + 1);
    }
  };

  const handleSpeak = (text: string) => {
    if ("speechSynthesis" in window) {
      const utterance = new SpeechSynthesisUtterance(text);
      utterance.lang = "en-US";
      window.speechSynthesis.speak(utterance);
    }
  };

  const handleCheckSpelling = () => {
    if (!currentReviewWord || !spellingInput.trim()) return;
    const cleanInput = spellingInput.trim().toLowerCase();
    const cleanWord = currentReviewWord.word.trim().toLowerCase();
    const isCorrect = cleanInput === cleanWord;
    setSpellingChecked(true);
    setSpellingResult(isCorrect ? "correct" : "incorrect");
  };

  const getSpellingHint = (word: string) => {
    if (!word) return "";
    const w = word.trim();
    if (w.length <= 2) return `${w.length} ${lang === "zh" ? "字母" : "letters"}`;
    return `${w[0]}${" _".repeat(w.length - 2)} ${w[w.length - 1]} (${w.length} ${lang === "zh" ? "字母" : "letters"})`;
  };

  const getMaskedSentence = (enText: string, word: string) => {
    if (!word || !enText) return "";
    const trimmed = word.trim();
    const regex = new RegExp(`\\b${trimmed}\\w*\\b`, 'gi');
    return enText.replace(regex, '_________');
  };

  return (
    <div className="min-h-screen bg-slate-50 dark:bg-slate-950 font-sans text-slate-800 dark:text-slate-100 transition-colors duration-300">
      
      {/* Upper Navigation Header */}
      <header className="sticky top-0 z-40 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-100 dark:border-slate-800 transition-colors">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between gap-4">
          
          <div className="flex items-center gap-2.5">
            <div className="w-10 h-10 rounded-xl bg-indigo-600 dark:bg-indigo-500 flex items-center justify-center text-white shrink-0 shadow-sm shadow-indigo-1200 transition">
              <Sparkles className="w-5.5 h-5.5" />
            </div>
            <div>
              <h1 className="text-base font-bold tracking-tight text-slate-900 dark:text-slate-50" id="app-title-header">{T.brandName}</h1>
              <p className="text-[10px] text-slate-500 dark:text-slate-300 font-medium hidden sm:block">{T.tagline}</p>
            </div>
          </div>

          {/* Clean switches: Lang, Mode */}
          <div className="flex items-center gap-2.5">
            {/* Language Selection */}
            <button
              onClick={() => setLang(lang === "zh" ? "en" : "zh")}
              className="p-2 rounded-xl bg-slate-100 dark:bg-slate-950 hover:bg-slate-200 dark:hover:bg-slate-850 text-slate-600 dark:text-slate-200 transition flex items-center gap-1.5 text-xs font-semibold select-none border border-slate-200/40 dark:border-slate-800/60"
              title="切换语言 / Switch Language"
            >
              <Languages className="w-4 h-4 text-indigo-500 dark:text-indigo-400" />
              <span className="hidden xs:inline">{lang === "zh" ? "EN" : "中文"}</span>
            </button>

            {/* Light/Dark Toggle */}
            <button
              onClick={() => setDarkMode(!darkMode)}
              className="p-2 rounded-xl bg-slate-100 dark:bg-slate-950 hover:bg-slate-200 dark:hover:bg-slate-850 text-slate-600 dark:text-slate-200 transition flex items-center gap-1.5 text-xs font-semibold select-none border border-slate-200/40 dark:border-slate-800/60"
              title="深浅模式 / Toggle Theme"
            >
              {darkMode ? <Sun className="w-4 h-4 text-amber-500" /> : <Moon className="w-4 h-4 text-slate-600" />}
              <span className="hidden xs:inline">{darkMode ? T.themeLight : T.themeDark}</span>
            </button>
          </div>
        </div>
      </header>

      <main className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
        
        {/* Top Floating Dashboard Actions */}
        <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-xs transition-all">
          <div className="space-y-0.5">
            <h2 className="text-base font-extrabold text-slate-900 dark:text-slate-100">
              {lang === "zh" ? "积累主动词汇" : "Active vocabulary"}
            </h2>
            <p className="text-[11px] text-slate-500 dark:text-slate-400">
              {lang === "zh" ? "记录实际遇到的生词，或通过 AI 批量解析您的阅读文章提取候选词。" : "Review self-captured words or scan texts to build highly persistent expressive memory."}
            </p>
          </div>

          {/* Action triggers */}
          <div className="flex flex-wrap gap-2.5 shrink-0">
            <button
              onClick={() => {
                setIsScannerOpen(false);
                setIsAddOpen(true);
              }}
              className="bg-indigo-600 hover:bg-indigo-700 dark:bg-indigo-550 dark:hover:bg-indigo-650 text-white text-xs font-semibold px-4 py-2.5 rounded-xl flex items-center gap-1.5 transition shadow-sm"
            >
              <Plus className="w-4.5 h-4.5" />
              {T.actionAdd}
            </button>
            <button
              onClick={() => {
                setIsAddOpen(false);
                setIsScannerOpen(!isScannerOpen);
              }}
              className="bg-emerald-600 hover:bg-emerald-700 dark:bg-emerald-650 dark:hover:bg-emerald-555 text-white text-xs font-semibold px-4 py-2.5 rounded-xl flex items-center gap-1.5 transition shadow-sm"
            >
              <Sparkles className="w-4.5 h-4.5" />
              {T.actionScan}
            </button>
          </div>
        </div>

        {/* Dynamic scanner component mount */}
        {isScannerOpen && (
          <div className="bg-slate-100/30 dark:bg-slate-950/20 p-1.5 rounded-3xl border border-slate-100 dark:border-slate-850 animate-fade-in">
            <TextImportScanner
              notebooks={notebooks}
              defaultNotebookId={notebooks[0]?.id || "notebook-default"}
              onImportComplete={() => {
                reloadWords();
              }}
              lang={lang}
            />
          </div>
        )}

        {/* Dashboard Metrics Binders */}
        <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
          
          <div 
            onClick={() => setStageFilter(stageFilter === "due" ? "all" : "due")}
            className={`p-5 rounded-2xl border transition-all cursor-pointer select-none ${
              dueWords.length > 0 
                ? "bg-amber-500/[0.04] hover:bg-amber-500/[0.08] border-amber-500/20 text-amber-900 dark:text-amber-400" 
                : "bg-white dark:bg-slate-900 border-slate-100 dark:border-slate-800 hover:border-slate-200"
            }`}
          >
            <div className="flex items-center justify-between">
              <Clock className={`w-5 h-5 ${dueWords.length > 0 ? "text-amber-500 animate-pulse" : "text-slate-400"}`} />
              {dueWords.length > 0 && (
                <span className="text-[9px] font-bold px-2 py-0.5 rounded-full bg-amber-500 text-white uppercase tracking-wider">
                  DUE NOW
                </span>
              )}
            </div>
            <p className="text-2xl font-black mt-3 tracking-tight">{dueWords.length}</p>
            <p className="text-xs font-bold text-slate-800 dark:text-slate-200 mt-1">{T.statDue}</p>
            <p className="text-[10px] text-slate-400 dark:text-slate-300 mt-0.5">{T.statDueSub}</p>
          </div>

          <div className="p-5 bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-xs transition-colors">
            <BookOpen className="w-5 h-5 text-indigo-550 dark:text-indigo-400" />
            <p className="text-2xl font-black mt-3 tracking-tight">{totalCount}</p>
            <p className="text-xs font-bold text-slate-800 dark:text-slate-200 mt-1">{T.statTotal}</p>
            <p className="text-[10px] text-slate-400 dark:text-slate-300 mt-0.5">{T.statTotalSub}</p>
          </div>

          <div 
            onClick={() => setStageFilter(stageFilter === "master" ? "all" : "master")}
            className="p-5 bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-xs hover:border-slate-200 dark:hover:border-slate-700 transition-colors cursor-pointer"
          >
            <CheckCircle2 className="w-5 h-5 text-emerald-500" />
            <p className="text-2xl font-black mt-3 tracking-tight">{masteryWords.length}</p>
            <p className="text-xs font-bold text-slate-800 dark:text-slate-200 mt-1">{T.statMastery}</p>
            <p className="text-[10px] text-slate-400 dark:text-slate-300 mt-0.5">{T.statMasterySub}</p>
          </div>

          <div className="p-5 bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-xs transition-colors">
            <Layers className="w-5 h-5 text-slate-500" />
            <p className="text-2xl font-black mt-3 tracking-tight">{notebooks.length}</p>
            <p className="text-xs font-bold text-slate-800 dark:text-slate-200 mt-1">{T.statNotebooks}</p>
            <p className="text-[10px] text-slate-400 dark:text-slate-300 mt-0.5">{T.statNotebooksSub}</p>
          </div>
        </div>

        {/* TWO-COLUMN GRID: Left Main rep deck & lists, Right simple guidelines and notebooks */}
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
          
          {/* Main Area: Review deck & Word Catalog list */}
          <div className="lg:col-span-2 space-y-8">
            
            {/* EBBINGHAUS SPECIAL DECK */}
            <section className="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 shadow-xs transition-all p-6 md:p-8 space-y-5">
              
              <div className="flex items-center justify-between border-b border-slate-100 dark:border-slate-800 pb-4 flex-wrap gap-2">
                <div>
                  <h3 className="text-sm font-bold text-slate-800 dark:text-slate-100 uppercase tracking-wider flex items-center gap-1.5">
                    <Clock className="w-4 h-4 text-indigo-650" />
                    {T.deckHeader}
                  </h3>
                  <p className="text-xs text-slate-500 dark:text-slate-300 mt-1">{T.deckSub}</p>
                </div>

                {dueWords.length > 0 && !reviewMode && (
                  <button
                    onClick={() => {
                      setReviewMode(true);
                      setIsGeneralPractice(false);
                      setCurrentReviewIndex(0);
                      setAnswerRevealed(false);
                    }}
                    className="bg-amber-500 hover:bg-amber-600 dark:bg-amber-650 dark:hover:bg-amber-550 text-white font-bold text-xs py-2 px-4 rounded-xl shadow-xs transition"
                  >
                    {lang === "zh" ? `立即开始 ${dueWords.length} 词专项复习` : `Launch Review (${dueWords.length} words)`}
                  </button>
                )}
              </div>

              {/* Deck Presentation Cards */}
              {reviewMode && currentReviewWord ? (
                <div className="bg-slate-50 dark:bg-slate-950 p-6 rounded-2xl border border-slate-100 dark:border-slate-800 space-y-5 transition-colors duration-200">
                  
                  {/* Word indicators along with Practice Type Toggle */}
                  <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-b border-slate-200/50 dark:border-slate-800/50 pb-3.5">
                    <span className="text-[10px] bg-indigo-100 dark:bg-indigo-950 text-indigo-800 dark:text-indigo-350 py-1 px-2.5 rounded-full font-bold uppercase tracking-wider">
                      {T.reviewRound} {currentReviewIndex + 1} / {activeReviewQueue.length}
                    </span>

                    {/* Mode Segment Switcher */}
                    <div className="flex bg-slate-250 dark:bg-slate-900 p-0.5 rounded-lg text-[11px] font-bold">
                      <button
                        type="button"
                        onClick={() => setReviewType("card")}
                        className={`px-3 py-1 rounded-md transition ${reviewType === "card" ? "bg-white dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 shadow-xs" : "text-slate-500 dark:text-slate-400 hover:text-slate-850 dark:hover:text-slate-200"}`}
                      >
                        {T.practiceTypeCard}
                      </button>
                      <button
                        type="button"
                        onClick={() => setReviewType("spelling")}
                        className={`px-3 py-1 rounded-md transition ${reviewType === "spelling" ? "bg-white dark:bg-slate-800 text-indigo-600 dark:text-indigo-400 shadow-xs" : "text-slate-500 dark:text-slate-400 hover:text-slate-850 dark:hover:text-slate-200"}`}
                      >
                        {T.practiceTypeSpelling}
                      </button>
                    </div>

                    <span className="text-xs text-slate-500 dark:text-slate-300 font-semibold italic">
                      {isGeneralPractice ? T.btnStopGeneral : T.nextInLine(activeReviewQueue.length - currentReviewIndex)}
                    </span>
                  </div>

                  {/* CHOOSE INTERFACE ACCORDING TO ACTIVE PRACTISE TYPE */}
                  {reviewType === "card" ? (
                    <div className="space-y-5">
                      {/* Standard Flashcard View */}
                      <div className="text-center py-6 space-y-2">
                        <h4 className="text-3xl font-extrabold text-slate-900 dark:text-slate-100 tracking-tight">
                          {currentReviewWord.word}
                        </h4>
                        <div className="flex items-center justify-center gap-1.5">
                          <span className="text-xs text-slate-500 dark:text-slate-300 font-mono">{currentReviewWord.pos} {currentReviewWord.phonetic}</span>
                          <button
                            onClick={() => handleSpeak(currentReviewWord.word)}
                            className="p-1 rounded bg-slate-200 dark:bg-slate-800 text-slate-600 dark:text-slate-200 hover:bg-slate-300 transition"
                            title="朗读"
                          >
                            <Volume2 className="w-3.5 h-3.5" />
                          </button>
                        </div>

                        {/* Context sentence on front (Excellent Memory Clue) */}
                        {currentReviewWord.sentences && currentReviewWord.sentences.length > 0 && (
                          <p className="text-xs italic text-slate-600 dark:text-slate-300 mt-4 max-w-lg mx-auto leading-relaxed border-t border-slate-200/50 dark:border-slate-800 pt-3">
                            &ldquo;{currentReviewWord.sentences[0].en}&rdquo;
                          </p>
                        )}
                      </div>

                      {/* Action or reveal results */}
                      {!answerRevealed ? (
                        <div className="pt-2 text-center">
                          <button
                            onClick={() => setAnswerRevealed(true)}
                            className="w-full bg-indigo-650 hover:bg-indigo-755 text-white py-3 rounded-xl text-xs font-bold tracking-wider max-w-sm mx-auto block shadow-sm"
                          >
                            {T.btnReveal}
                          </button>
                        </div>
                      ) : (
                        <div className="space-y-4 border-t border-slate-200 dark:border-slate-800 pt-5 animate-fade-in">
                          
                          {/* Bilingual Translation values */}
                          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div className="space-y-1">
                              <span className="text-[10px] font-bold text-slate-400 dark:text-slate-300 uppercase tracking-widest">{T.wordChinese}</span>
                              <p className="text-sm font-bold text-indigo-950 dark:text-indigo-350">{currentReviewWord.chineseDefinition}</p>
                              {currentReviewWord.englishDefinition && (
                                <p className="text-xs text-slate-600 dark:text-slate-300 italic mt-1">{currentReviewWord.englishDefinition}</p>
                              )}
                            </div>

                            {currentReviewWord.memoryHook && (
                              <div className="space-y-1 p-3 bg-amber-500/[0.03] rounded-xl border border-amber-500/10">
                                <span className="text-[10px] font-bold text-amber-800 dark:text-amber-400 uppercase tracking-widest flex items-center gap-1">
                                  <Lightbulb className="w-3 h-3 text-amber-500" />
                                  {T.wordMemory}
                                </span>
                                <p className="text-xs text-slate-700 dark:text-slate-300 leading-relaxed font-medium">{currentReviewWord.memoryHook}</p>
                              </div>
                            )}
                          </div>

                          {/* Phrases and details */}
                          {currentReviewWord.rootAffix && (
                            <div className="text-xs bg-slate-100/50 dark:bg-slate-900/50 p-3 rounded-xl border border-slate-200/50 dark:border-slate-800">
                              <span className="font-semibold text-slate-700 dark:text-slate-200 block mb-0.5">{T.wordRoot}</span>
                              <span className="text-slate-600 dark:text-slate-300 leading-relaxed">{currentReviewWord.rootAffix}</span>
                            </div>
                          )}

                          {/* Sentence ZH translated */}
                          {currentReviewWord.sentences && currentReviewWord.sentences.length > 0 && currentReviewWord.sentences[0].zh && (
                            <div className="text-xs text-slate-500 dark:text-slate-300 italic">
                              💡 {currentReviewWord.sentences[0].zh}
                            </div>
                          )}

                          {/* Assessment Rating buttons */}
                          <div className="grid grid-cols-2 gap-3 pt-3">
                            <button
                              onClick={() => handleRateReview("incorrect")}
                              className="bg-rose-50 dark:bg-rose-950/20 text-rose-700 dark:text-rose-450 border border-rose-200 dark:border-rose-900/50 hover:bg-rose-100 transition rounded-xl py-3 text-xs font-bold"
                            >
                              {T.btnForgot}
                            </button>
                            <button
                              onClick={() => handleRateReview("correct")}
                              className="bg-emerald-600 hover:bg-emerald-700 text-white transition rounded-xl py-3 text-xs font-bold flex items-center justify-center gap-1.5 shadow-xs"
                            >
                              <Check className="w-4 h-4" />
                              {T.btnGotIt}
                            </button>
                          </div>
                        </div>
                      )}
                    </div>
                  ) : (
                    <div className="space-y-5 animate-fade-in">
                      {/* SPELLING PRACTICE DICTATION INTERFACE */}
                      <div className="text-center py-4 space-y-3">
                        <div className="inline-block px-3 py-1 rounded-full text-[11px] font-bold bg-indigo-50 dark:bg-indigo-950/40 text-indigo-700 dark:text-indigo-400 border border-indigo-100 dark:border-indigo-900/40">
                          {currentReviewWord.pos} • {currentReviewWord.phonetic || "Speaker available"}
                        </div>
                        
                        <div className="space-y-1">
                          <span className="text-[10px] font-bold text-slate-400 dark:text-slate-300 uppercase tracking-widest block">{T.wordChinese}</span>
                          <h4 className="text-xl font-extrabold text-indigo-950 dark:text-indigo-300 max-w-md mx-auto leading-normal">
                            {currentReviewWord.chineseDefinition}
                          </h4>
                        </div>

                        {/* First and Last letter hint */}
                        <div className="pt-2">
                          <span className="text-[10px] font-bold text-slate-500 dark:text-slate-300 uppercase tracking-widest block mb-1">{T.spellingHintLabel}</span>
                          <span className="text-base font-mono font-bold tracking-widest text-slate-600 dark:text-slate-100 bg-slate-200/55 dark:bg-slate-900 px-3 py-1.5 rounded-lg inline-block">
                            {getSpellingHint(currentReviewWord.word)}
                          </span>
                        </div>

                        {/* Audio dictation trigger */}
                        <div className="flex items-center justify-center gap-1.5 pt-1">
                          <button
                            type="button"
                            onClick={() => handleSpeak(currentReviewWord.word)}
                            className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-indigo-50 hover:bg-indigo-100 dark:bg-indigo-950/25 dark:hover:bg-indigo-900/40 text-xs font-bold text-indigo-650 dark:text-indigo-400 transition"
                          >
                            <Volume2 className="w-4 h-4" />
                            {lang === "zh" ? "播放标准发音 (听音朗读)" : "Play Audio Dictation"}
                          </button>
                        </div>
                      </div>

                      {/* Context Hint card with masked word */}
                      {currentReviewWord.sentences && currentReviewWord.sentences.length > 0 && (
                        <div className="bg-slate-100/50 dark:bg-slate-900/60 p-4 rounded-xl border border-slate-200/40 dark:border-slate-800/60 text-center space-y-1.5">
                          <span className="text-[10px] uppercase font-bold text-slate-400 dark:text-slate-300 tracking-wider">上下文语境提示 (Context clue)</span>
                          <p className="text-sm italic font-medium text-slate-700 dark:text-slate-300 leading-relaxed">
                            &ldquo;{getMaskedSentence(currentReviewWord.sentences[0].en, currentReviewWord.word)}&rdquo;
                          </p>
                          {spellingChecked && currentReviewWord.sentences[0].zh && (
                            <p className="text-xs text-slate-500 dark:text-slate-300 italic mt-1">
                              👉 {currentReviewWord.sentences[0].zh}
                            </p>
                          )}
                        </div>
                      )}

                      {/* Input spelling response area */}
                      {spellingChecked ? (
                        <div className="space-y-4 pt-1 animate-fade-in">
                          <div className={`p-4 rounded-xl border text-center ${
                            spellingResult === "correct"
                              ? "bg-emerald-500/[0.03] border-emerald-500/20 text-emerald-800 dark:text-emerald-400"
                              : "bg-rose-500/[0.03] border-rose-500/20 text-rose-800 dark:text-rose-450"
                          }`}>
                            <p className="text-xs font-extrabold flex items-center justify-center gap-1.5">
                              {spellingResult === "correct" ? T.spellingCorrectBadge : T.spellingIncorrectBadge}
                            </p>
                            
                            <div className="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs max-w-sm mx-auto text-left py-2 border-t border-slate-200/50 dark:border-slate-800/50">
                              <div>
                                <span className="text-[10px] text-slate-400 block font-bold uppercase">{T.spellingExpectedLabel}</span>
                                <span className="font-mono font-bold text-slate-800 dark:text-slate-200 text-sm whitespace-nowrap">{currentReviewWord.word}</span>
                              </div>
                              <div>
                                <span className="text-[10px] text-slate-400 block font-bold uppercase">{T.spellingYourLabel}</span>
                                <span className="font-mono font-bold text-slate-800 dark:text-slate-200 text-sm truncate block">{spellingInput || "(空)"}</span>
                              </div>
                            </div>
                          </div>

                          {currentReviewWord.memoryHook && (
                            <div className="p-3 bg-amber-500/[0.03] rounded-xl border border-amber-500/10 text-xs">
                              <span className="font-semibold text-amber-800 dark:text-amber-400 block mb-0.5">{T.wordMemory}</span>
                              <span className="text-slate-600 dark:text-slate-400 leading-relaxed">{currentReviewWord.memoryHook}</span>
                            </div>
                          )}

                          {/* Control Assessment Actions */}
                          <div className="grid grid-cols-2 gap-3 pt-2">
                            {spellingResult === "incorrect" ? (
                              <button
                                type="button"
                                onClick={() => {
                                  setSpellingChecked(false);
                                  setSpellingResult(null);
                                }}
                                className="border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 hover:bg-slate-50 transition rounded-xl py-3 text-xs font-bold"
                              >
                                {T.btnRetrySpelling}
                              </button>
                            ) : (
                              <button
                                type="button"
                                onClick={() => handleRateReview("incorrect")}
                                className="bg-rose-50 dark:bg-rose-950/20 text-rose-700 dark:text-rose-450 border border-rose-200 dark:border-rose-900/50 hover:bg-rose-100 transition rounded-xl py-3 text-xs font-bold"
                              >
                                {T.btnForgot}
                              </button>
                            )}
                            <button
                              type="button"
                              onClick={() => handleRateReview("correct")}
                              className="bg-emerald-600 hover:bg-emerald-700 text-white transition rounded-xl py-3 text-xs font-bold flex items-center justify-center gap-1.5 shadow-xs"
                            >
                              <Check className="w-4 h-4" />
                              {T.btnGotIt}
                            </button>
                          </div>
                        </div>
                      ) : (
                        <div className="pt-2 space-y-3">
                          <div className="relative">
                            <input
                              type="text"
                              value={spellingInput}
                              onChange={(e) => setSpellingInput(e.target.value)}
                              onKeyDown={(e) => {
                                if (e.key === "Enter" && spellingInput.trim()) {
                                  handleCheckSpelling();
                                }
                              }}
                              placeholder={T.spellingInputPlacer}
                              className="w-full text-center font-mono text-sm tracking-wide p-3.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-indigo-500 shadow-inner"
                              autoFocus
                            />
                          </div>
                          <button
                            type="button"
                            onClick={handleCheckSpelling}
                            disabled={!spellingInput.trim()}
                            className="w-full bg-indigo-650 hover:bg-indigo-755 disabled:opacity-50 disabled:cursor-not-allowed text-white py-3 rounded-xl text-xs font-bold tracking-wider transition shadow-sm"
                          >
                            {T.btnCheckSpelling}
                          </button>
                        </div>
                      )}
                    </div>
                  )}

                  {/* Footer level stage details */}
                  <div className="flex justify-between items-center text-[10px] text-slate-500 dark:text-slate-350 pt-3 border-t border-slate-200/50 dark:border-slate-800/50">
                    <span>
                      {lang === "zh" ? "当前生词艾宾浩斯记忆高度：" : "Cognitive Height: "} 
                      Stage {currentReviewWord.stage} (
                      {lang === "zh" ? STAGE_LABELS[currentReviewWord.stage] : STAGE_LABELS_EN[currentReviewWord.stage]}
                      )
                    </span>
                    <button
                      type="button"
                      onClick={() => {
                        setReviewMode(false);
                        setIsGeneralPractice(false);
                      }}
                      className="text-indigo-600 dark:text-indigo-400 hover:underline font-bold"
                    >
                      {T.btnCancel}
                    </button>
                  </div>
                </div>
              ) : (
                <div className="text-center py-8 space-y-4">
                  {dueWords.length === 0 ? (
                    <div className="space-y-2">
                      <div className="w-12 h-12 bg-emerald-50 dark:bg-emerald-950/40 text-emerald-600 dark:text-emerald-450 rounded-full flex items-center justify-center mx-auto shadow-xs border border-emerald-100 dark:border-emerald-900">
                        <Check className="w-6 h-6" />
                      </div>
                      <h4 className="text-sm font-bold text-slate-800 dark:text-slate-200 mt-3">{T.deckEmptyAll}</h4>
                      <p className="text-xs text-slate-500 dark:text-slate-300 max-w-lg mx-auto leading-relaxed">
                        {T.deckEmptySub}
                      </p>
                    </div>
                  ) : (
                    <div className="space-y-3">
                      <p className="text-xs text-amber-800 dark:text-amber-400 font-bold bg-amber-500/[0.05] border border-amber-500/10 rounded-xl max-w-md mx-auto py-2.5 px-4">
                        ⚠️ 有 <strong>{dueWords.length}</strong> 个词处于艾宾浩斯记忆临界点，建议立即自评巩固。
                      </p>
                    </div>
                  )}

                  {/* Secondary/Universal triggers */}
                  <div className="pt-2">
                    {words.length > 0 && (
                      <button
                        onClick={() => {
                          setIsGeneralPractice(true);
                          setReviewMode(true);
                          setCurrentReviewIndex(0);
                          setAnswerRevealed(false);
                        }}
                        className="text-xs font-bold border border-slate-200 dark:border-slate-800 hover:bg-slate-100 dark:hover:bg-slate-950 text-slate-600 dark:text-slate-300 px-5 py-3 rounded-xl transition shadow-xs"
                      >
                        {T.btnGeneralPractice}
                      </button>
                    )}
                  </div>
                </div>
              )}
            </section>

            {/* REGISTERED WORD CATALOGUE */}
            <section className="space-y-4">
              
              <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <h3 className="text-md font-extrabold text-slate-800 dark:text-slate-100 flex items-center gap-1.5">
                  <BookOpen className="w-5 h-5 text-indigo-600 dark:text-indigo-400" />
                  {T.catalogTitle} ({filteredWords.length})
                </h3>

                {/* Search word layout */}
                <div className="relative w-full sm:max-w-xs">
                  <input
                    type="text"
                    value={searchQuery}
                    onChange={(e) => setSearchQuery(e.target.value)}
                    placeholder={T.searchPlacer}
                    className="w-full pl-9 pr-4 py-2 text-xs rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 text-slate-900 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                  />
                  <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400 dark:text-slate-500" />
                </div>
              </div>

              {/* Fast level tags categories filters */}
              <div className="flex flex-row sm:flex-wrap items-center gap-1.5 text-xs select-none overflow-x-auto scrollbar-none pb-1 -mx-4 px-4 sm:mx-0 sm:px-0">
                {/* Stage Filters */}
                <button
                  type="button"
                  onClick={() => setStageFilter("all")}
                  className={`px-3 py-1.5 rounded-xl font-bold transition shrink-0 ${
                    stageFilter === "all" 
                      ? "bg-slate-900 dark:bg-slate-100 text-white dark:text-slate-900 shadow-sm" 
                      : "bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-350 hover:bg-slate-100 dark:hover:bg-slate-800 border border-slate-200/50 dark:border-slate-800 shadow-xs"
                  }`}
                >
                  {lang === "zh" ? "全部" : "All"}
                </button>
                <button
                  type="button"
                  onClick={() => setStageFilter("due")}
                  className={`px-3 py-1.5 rounded-xl font-bold transition shrink-0 ${
                    stageFilter === "due"
                      ? "bg-amber-500 text-white shadow-sm"
                      : "bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-350 hover:bg-slate-100 dark:hover:bg-slate-800 border border-slate-200/50 dark:border-slate-800 shadow-xs"
                  }`}
                >
                  ⏳ {lang === "zh" ? "待复习" : "Due"}
                </button>
                <button
                  type="button"
                  onClick={() => setStageFilter("new")}
                  className={`px-3 py-1.5 rounded-xl font-bold transition shrink-0 ${
                    stageFilter === "new"
                      ? "bg-indigo-100 text-indigo-900 dark:bg-indigo-950 dark:text-indigo-200 shadow-sm font-bold"
                      : "bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-350 hover:bg-slate-100 dark:hover:bg-slate-800 border border-slate-200/50 dark:border-slate-800 shadow-xs"
                  }`}
                >
                  🆕 {lang === "zh" ? "未初记 (0阶)" : "Unlearned (S0)"}
                </button>
                <button
                  type="button"
                  onClick={() => setStageFilter("learning")}
                  className={`px-3 py-1.5 rounded-xl font-bold transition shrink-0 ${
                    stageFilter === "learning"
                      ? "bg-indigo-600 text-white shadow-sm"
                      : "bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-350 hover:bg-slate-100 dark:hover:bg-slate-800 border border-slate-200/50 dark:border-slate-800 shadow-xs"
                  }`}
                >
                  📈 {lang === "zh" ? "学习中 (1-6阶)" : "Learning (S1-6)"}
                </button>
                <button
                  type="button"
                  onClick={() => setStageFilter("master")}
                  className={`px-3 py-1.5 rounded-xl font-bold transition shrink-0 ${
                    stageFilter === "master"
                      ? "bg-emerald-600 text-white shadow-sm"
                      : "bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-350 hover:bg-slate-100 dark:hover:bg-slate-800 border border-slate-200/50 dark:border-slate-800 shadow-xs"
                  }`}
                >
                  🎓 {lang === "zh" ? "已掌握 (7-8阶)" : "Mastered (S7-8)"}
                </button>
              </div>

              {/* Rows catalog list */}
              {filteredWords.length > 0 ? (
                <div className="space-y-2.5">
                  {filteredWords.map((item) => {
                    const isDue = item.nextReviewAt <= Date.now();
                    const isExpanded = expandedWordId === item.id;
                    return (
                      <div
                        key={item.id}
                        className={`bg-white dark:bg-slate-900 rounded-xl border transition-all ${
                          isExpanded 
                            ? "border-indigo-400 shadow-md ring-2 ring-indigo-50 dark:ring-indigo-950/25" 
                            : "border-slate-100 dark:border-slate-800/80 hover:border-slate-200 dark:hover:border-slate-750"
                        }`}
                      >
                        
                        {/* Word summary row */}
                        <div
                          onClick={() => setExpandedWordId(isExpanded ? null : item.id)}
                          className="p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3 cursor-pointer select-none"
                        >
                          <div className="flex flex-col sm:flex-row sm:items-center gap-2.5">
                            <span className="text-base font-extrabold text-slate-900 dark:text-slate-50 tracking-tight">
                              {item.word}
                            </span>
                            <div className="flex flex-wrap gap-1.5 items-center">
                              <span className="text-[10px] text-slate-400 font-mono italic">
                                {item.pos} {item.phonetic}
                              </span>
                              
                              <span className="text-[9px] font-bold px-2 py-0.5 rounded-full bg-slate-100 dark:bg-slate-950 border border-slate-200/40 dark:border-slate-850/60 text-indigo-650 dark:text-indigo-400">
                                Stage {item.stage}
                              </span>

                              {isDue && (
                                <span className="text-[9px] font-bold px-1.5 py-0.5 bg-amber-500/10 dark:bg-amber-950/40 text-amber-700 dark:text-amber-400 rounded-sm">
                                  {T.wordNextReviewDue}
                                </span>
                              )}
                            </div>
                          </div>

                          <div className="flex items-center justify-between sm:justify-end gap-3">
                            <p className="text-xs text-slate-700 dark:text-slate-300 font-medium truncate max-w-xs md:max-w-md">
                              {item.chineseDefinition}
                            </p>
                            
                            {isExpanded ? <ChevronUp className="w-4.5 h-4.5 text-slate-400" /> : <ChevronDown className="w-4.5 h-4.5 text-slate-400" />}
                          </div>
                        </div>

                        {/* Expandable details card */}
                        {isExpanded && (
                          <div className="px-5 pb-5 border-t border-slate-100 dark:border-slate-800/80 pt-4 space-y-4 animate-fade-in bg-slate-50/[0.02] dark:bg-slate-950/[0.05]">
                            
                            {/* Pronounce & Delete Controls */}
                            <div className="flex items-center justify-between border-b border-dashed border-slate-100 dark:border-slate-800 pb-3">
                              <div className="flex gap-2">
                                <button
                                  onClick={() => handleSpeak(item.word)}
                                  className="text-xs font-semibold px-2 py-1.5 rounded-lg bg-slate-100 hover:bg-slate-200 dark:bg-slate-950 dark:hover:bg-slate-850 text-slate-750 dark:text-slate-300 flex items-center gap-1.5 transition select-none"
                                >
                                  <Volume2 className="w-3.5 h-3.5" />
                                  朗读发音 (Speak)
                                </button>
                              </div>

                              <button
                                onClick={() => handleWordDeleted(item.id)}
                                className="p-1 px-3 text-[10px] font-semibold text-rose-600 hover:bg-rose-50 dark:hover:bg-rose-950/20 rounded-lg flex items-center gap-1 transition"
                              >
                                <Trash2 className="w-3.5 h-3.5" />
                                彻底销毁
                              </button>
                            </div>

                            {/* Deep translation, English, Etymology */}
                            <div className="grid grid-cols-1 md:grid-cols-2 gap-5 text-xs">
                              <div className="space-y-2">
                                <span className="block font-bold text-slate-450 uppercase tracking-widest">{T.wordChinese}</span>
                                <p className="text-sm font-bold text-indigo-950 dark:text-indigo-300 bg-indigo-50/20 dark:bg-indigo-950/10 p-2 rounded-lg leading-relaxed">
                                  {item.chineseDefinition}
                                </p>
                                
                                {item.englishDefinition && (
                                  <>
                                    <span className="block font-bold text-slate-450 uppercase tracking-widest mt-1">{T.wordEnglish}</span>
                                    <p className="text-slate-650 dark:text-slate-400 italic bg-white dark:bg-slate-950 p-2.5 rounded-lg border border-slate-105 dark:border-slate-800">
                                      {item.englishDefinition}
                                    </p>
                                  </>
                                )}
                              </div>

                              {/* Memory Booster */}
                              <div className="bg-amber-500/[0.02] dark:bg-amber-955/[0.02] border border-amber-500/10 rounded-xl p-4 space-y-3">
                                <span className="font-bold text-amber-850 dark:text-amber-400 flex items-center gap-1 leading-none">
                                  <Lightbulb className="w-3.5 h-3.5 text-amber-500" />
                                  {T.wordMemory}
                                </span>
                                {item.memoryHook ? (
                                  <p className="text-slate-650 dark:text-slate-300 leading-relaxed font-medium bg-white dark:bg-slate-950 p-2.5 rounded-lg border border-amber-100/50 dark:border-amber-900/30">
                                    {item.memoryHook}
                                  </p>
                                ) : (
                                  <span className="text-slate-450 italic">未配置助记逻辑。您可以在手动录入时由 AI 为您定制。</span>
                                )}
                              </div>
                            </div>

                            {/* Prefix/Etymology logic row */}
                            {item.rootAffix && (
                              <div className="p-3 bg-slate-100/40 dark:bg-slate-950/30 border border-slate-205/40 dark:border-slate-800/80 rounded-xl text-xs space-y-1">
                                <span className="font-bold text-slate-700 dark:text-slate-300 block">{T.wordRoot}</span>
                                <p className="text-slate-600 dark:text-slate-400 leading-relaxed">{item.rootAffix}</p>
                              </div>
                            )}

                            {/* Common phrases */}
                            {item.phrases && item.phrases.length > 0 && (
                              <div className="text-xs space-y-1">
                                <span className="font-bold text-slate-450 uppercase tracking-widest">{T.wordPhrases}</span>
                                <div className="flex flex-wrap gap-2 pt-1">
                                  {item.phrases.map((ph, idx) => (
                                    <span
                                      key={idx}
                                      className="px-2.5 py-1 rounded bg-indigo-50 dark:bg-indigo-950/20 border border-indigo-100/60 dark:border-indigo-900 text-indigo-950 dark:text-indigo-350 font-medium"
                                    >
                                      {ph}
                                    </span>
                                  ))}
                                </div>
                              </div>
                            )}

                            {/* Examples */}
                            {item.sentences && item.sentences.length > 0 && (
                              <div className="text-xs space-y-2">
                                <span className="font-bold text-slate-450 uppercase tracking-widest">{T.wordExample}</span>
                                <div className="space-y-2 bg-white dark:bg-slate-950 p-3 rounded-xl border border-slate-105 dark:border-slate-800">
                                  {item.sentences.map((sent, index) => (
                                    <div key={index} className="space-y-1 select-text border-b border-slate-100 dark:border-slate-900/40 last:border-b-0 pb-1.5 last:pb-0">
                                      <p className="font-semibold text-slate-900 dark:text-slate-100 flex items-start gap-1">
                                        <span className="text-indigo-600 dark:text-indigo-400">{index + 1}.</span>
                                        <span>{sent.en}</span>
                                      </p>
                                      {sent.zh && <p className="text-slate-600 dark:text-slate-400 italic pl-4 text-[11px]">{sent.zh}</p>}
                                    </div>
                                  ))}
                                </div>
                              </div>
                            )}

                            {/* Study notes / Remarks */}
                            {item.notes && (
                              <div className="text-xs p-2.5 rounded-lg border border-slate-200 dark:border-slate-850 dark:bg-slate-900 text-slate-600 dark:text-slate-400">
                                📝 <strong className="text-slate-700 dark:text-slate-350">{T.wordNotes}:</strong> {item.notes}
                              </div>
                            )}

                            {/* Timeline intervals calculations details */}
                            <div className="pt-3 border-t border-slate-100 dark:border-slate-800 flex flex-col sm:flex-row items-center justify-between text-[11px] text-slate-500 gap-2 font-medium">
                              <span className="flex items-center gap-1">
                                <Layers className="w-3.5 h-3.5 text-indigo-550" />
                                {T.wordStageLabel}: <strong className="text-slate-800 dark:text-slate-200">Stage {item.stage}</strong> ({lang === "zh" ? STAGE_LABELS[item.stage] || "终期" : STAGE_LABELS_EN[item.stage] || "Mastered"})
                              </span>
                              <span>
                                {T.wordNextReview}: <strong className="text-slate-800 dark:text-slate-200">{new Date(item.nextReviewAt).toLocaleDateString()} {new Date(item.nextReviewAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</strong>
                              </span>
                            </div>

                            {/* Review Attempt lists metric logs logs */}
                            {item.reviewHistory && item.reviewHistory.length > 0 && (
                              <div className="pt-1.5 border-t border-slate-100 dark:border-slate-850">
                                <span className="block text-[10px] font-bold text-slate-450 uppercase tracking-widest mb-1.5">{T.wordReviewHistory}</span>
                                <div className="flex flex-wrap gap-1.5">
                                  {item.reviewHistory.map((hist, hIdx) => (
                                    <span
                                      key={hIdx}
                                      className={`text-[9px] px-2 py-0.5 rounded-full border flex items-center gap-1 ${
                                        hist.result === "correct"
                                          ? "bg-emerald-500/[0.03] dark:bg-emerald-950/20 text-emerald-800 dark:text-emerald-400 border-emerald-500/10"
                                          : "bg-rose-500/[0.03] dark:bg-rose-955/20 text-rose-800 dark:text-rose-400 border-rose-555/15"
                                      }`}
                                    >
                                      <span className={`w-1 h-1 rounded-full ${hist.result === "correct" ? "bg-emerald-555" : "bg-rose-555"}`} />
                                      {hist.result === "correct" ? T.histCorrect : T.histForgot} (S{hist.oldStage}&rarr;S{hist.newStage})
                                    </span>
                                  ))}
                                </div>
                              </div>
                            )}
                          </div>
                        )}
                      </div>
                    );
                  })}
                </div>
              ) : (
                <div className="text-center py-12 bg-white dark:bg-slate-900 rounded-2xl border border-slate-105 dark:border-slate-850 p-6">
                  <BookOpen className="w-10 h-10 text-slate-300 mx-auto mb-2" />
                  <p className="text-slate-550 dark:text-slate-400 text-xs font-semibold">{T.noWordsCatalog}</p>
                  
                  {words.length === 0 && (
                    <button
                      onClick={() => setIsAddOpen(true)}
                      className="mt-4 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs py-2 px-5 rounded-xl transition shadow-sm"
                    >
                      {T.addFirstWordBtn}
                    </button>
                  )}
                </div>
              )}
            </section>
          </div>

          {/* Right Area Sidebar: Instructions, Notebook tags */}
          <div className="space-y-6">

            {/* Ebbinghaus Stage Distribution Widget */}
            <div className="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 p-5 md:p-6 space-y-4 transition-colors">
              <div className="border-b border-slate-100 dark:border-slate-850 pb-3">
                <div className="flex items-center justify-between">
                  <h4 className="text-sm font-bold text-slate-850 dark:text-slate-200 flex items-center gap-1.5">
                    <Layers className="w-4 h-4 text-indigo-650 dark:text-indigo-400" />
                    {lang === "zh" ? "📊 艾宾浩斯遗忘梯队" : "📊 Ebbinghaus Curve Stages"}
                  </h4>
                  {stageFilter !== "all" && (
                    <button
                      onClick={() => setStageFilter("all")}
                      className="text-[10px] text-indigo-600 dark:text-indigo-400 font-bold hover:underline"
                    >
                      {lang === "zh" ? "重置筛选" : "Clear Filter"}
                    </button>
                  )}
                </div>
                <p className="text-[10px] text-slate-450 dark:text-slate-500 mt-1 leading-normal">
                  {lang === "zh" 
                    ? "点击下方各梯队即可在底部名册精准筛选对应阶段的单词。" 
                    : "Select a cognitive cohort below to filter corresponding lexical entries."}
                </p>
              </div>

              {/* Distribution bars */}
              <div className="space-y-1.5">
                {Array.from({ length: 9 }).map((_, stIndex) => {
                  const count = stageCounts[stIndex] || 0;
                  const percent = totalCount > 0 ? (count / totalCount) * 100 : 0;
                  const label = lang === "zh" ? STAGE_LABELS[stIndex] : STAGE_LABELS_EN[stIndex];
                  
                  // Color codes for stages: initial, reinforcement, mastery
                  let barColor = "from-amber-400 to-amber-500";
                  let bgBadge = "bg-amber-500/10 text-amber-700 dark:text-amber-400";
                  if (stIndex >= 3 && stIndex <= 5) {
                    barColor = "from-indigo-505 to-indigo-605";
                    bgBadge = "bg-indigo-500/10 text-indigo-700 dark:text-indigo-400";
                  } else if (stIndex >= 6) {
                    barColor = "from-emerald-500 to-emerald-600";
                    bgBadge = "bg-emerald-500/10 text-emerald-700 dark:text-emerald-400";
                  }

                  const isActiveFilter = stageFilter === String(stIndex);

                  return (
                    <button
                      type="button"
                      key={stIndex}
                      onClick={() => {
                        setStageFilter(isActiveFilter ? "all" : String(stIndex));
                      }}
                      className={`w-full text-left p-2 rounded-xl border transition-all flex flex-col gap-1 ${
                        isActiveFilter 
                          ? "bg-indigo-50/50 dark:bg-indigo-950/20 border-indigo-500/40 shadow-xs" 
                          : "bg-slate-50/40 dark:bg-slate-950/15 border-transparent hover:border-slate-200 dark:hover:border-slate-800"
                      }`}
                    >
                      <div className="flex items-center justify-between text-[11px] w-full font-semibold">
                        <div className="flex items-center gap-1.5 truncate">
                          <span className={`text-[9px] font-extrabold px-1.5 py-0.5 rounded ${bgBadge}`}>
                            S{stIndex}
                          </span>
                          <span className="text-slate-700 dark:text-slate-350 truncate">
                            {label.includes("（") ? label.split("（")[0] : label}
                          </span>
                          <span className="text-[9px] text-slate-400 dark:text-slate-500 font-mono">
                            {label.includes("（") ? `(${label.split("（")[1].replace("）", "")})` : ""}
                          </span>
                        </div>
                        <div className="flex items-center gap-1 font-mono text-[10px]">
                          <span className="text-slate-900 dark:text-slate-100 font-bold">{count} 词</span>
                          <span className="text-slate-400 dark:text-slate-500 font-normal">({percent.toFixed(0)}%)</span>
                        </div>
                      </div>

                      {/* Bar Gauge */}
                      <div className="w-full h-1.5 bg-slate-100 dark:bg-slate-850 rounded-full overflow-hidden relative">
                        <div 
                          className={`h-full bg-gradient-to-r ${barColor} transition-all duration-500 rounded-full`} 
                          style={{ width: `${totalCount > 0 ? Math.max(percent, count > 0 ? 3 : 0) : 0}%` }}
                        />
                      </div>
                    </button>
                  );
                })}
              </div>

              {/* Cognitive level overview summary cards */}
              <div className="grid grid-cols-3 gap-1.5 text-center pt-2.5 border-t border-slate-100 dark:border-slate-850 text-[9px] font-bold">
                <div 
                  onClick={() => setStageFilter(stageFilter === "new" ? "all" : "new")}
                  className={`p-1.5 rounded-lg border cursor-pointer transition ${
                    stageFilter === "new" 
                      ? "bg-amber-100/40 dark:bg-amber-950/20 border-amber-400/40" 
                      : "bg-amber-500/[0.02] border-amber-500/5 hover:border-amber-200"
                  }`}
                >
                  <span className="text-amber-600 dark:text-amber-400 block">⚡ {lang === "zh" ? "记忆初期" : "Early Stage"}</span>
                  <span className="text-slate-800 dark:text-slate-200 font-mono mt-0.5 block">{stageCounts[0] + stageCounts[1] + stageCounts[2]} 词</span>
                </div>
                <div 
                  onClick={() => setStageFilter(stageFilter === "learning" ? "all" : "learning")}
                  className={`p-1.5 rounded-lg border cursor-pointer transition ${
                    stageFilter === "learning" 
                      ? "bg-indigo-100/40 dark:bg-indigo-950/20 border-indigo-400/40" 
                      : "bg-indigo-500/[0.02] border-indigo-500/5 hover:border-indigo-200"
                  }`}
                >
                  <span className="text-indigo-600 dark:text-indigo-400 block">🧪 {lang === "zh" ? "中期强化" : "Spaced Rep"}</span>
                  <span className="text-slate-800 dark:text-slate-200 font-mono mt-0.5 block">{stageCounts[3] + stageCounts[4] + stageCounts[5]} 词</span>
                </div>
                <div 
                  onClick={() => setStageFilter(stageFilter === "master" ? "all" : "master")}
                  className={`p-1.5 rounded-lg border cursor-pointer transition ${
                    stageFilter === "master" 
                      ? "bg-emerald-100/40 dark:bg-emerald-950/20 border-emerald-400/40" 
                      : "bg-emerald-500/[0.02] border-emerald-500/5 hover:border-emerald-200"
                  }`}
                >
                  <span className="text-emerald-600 dark:text-emerald-400 block">🏆 {lang === "zh" ? "终期熟记" : "Mastery"}</span>
                  <span className="text-slate-800 dark:text-slate-200 font-mono mt-0.5 block">{stageCounts[6] + stageCounts[7] + stageCounts[8]} 词</span>
                </div>
              </div>
            </div>

            {/* Notebook manager card */}
            <div className="bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800 p-5 md:p-6 space-y-4 transition-colors">
              
              <div className="flex items-center justify-between border-b border-slate-100 dark:border-slate-850 pb-3">
                <h4 className="text-sm font-bold text-slate-800 dark:text-slate-200">
                  {T.booksTitle}
                </h4>
                <button
                  onClick={() => setShowNotebookCreator(!showNotebookCreator)}
                  className="text-xs text-indigo-600 dark:text-indigo-400 hover:underline font-bold"
                >
                  {T.btnNewNotebook}
                </button>
              </div>

              {/* Direct inline Notebook Creator */}
              {showNotebookCreator && (
                <form onSubmit={handleCreateNotebook} className="p-3.5 bg-slate-50 dark:bg-slate-950/60 rounded-xl border border-slate-200/60 dark:border-slate-850 space-y-3 animate-fade-in">
                  <h5 className="text-xs font-bold text-slate-700 dark:text-slate-300">{T.createNbTitle}</h5>
                  
                  <div>
                    <label className="block text-[10px] text-slate-450 dark:text-slate-400 font-bold uppercase tracking-widest mb-1">{T.createNbName}</label>
                    <input
                      type="text"
                      required
                      value={newNbName}
                      onChange={(e) => setNewNbName(e.target.value)}
                      placeholder="e.g. GRE 写作核心词..."
                      className="w-full text-xs p-2 rounded-lg border border-slate-200 dark:border-slate-755 bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100"
                    />
                  </div>

                  <div>
                    <label className="block text-[10px] text-slate-450 dark:text-slate-400 font-bold uppercase tracking-widest mb-1">{T.createNbDesc}</label>
                    <input
                      type="text"
                      value={newNbDesc}
                      onChange={(e) => setNewNbDesc(e.target.value)}
                      placeholder="备考专用分类..."
                      className="w-full text-xs p-2 rounded-lg border border-slate-200 dark:border-slate-755 bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100"
                    />
                  </div>

                  <div className="flex justify-end gap-2 pt-1.5">
                    <button
                      type="button"
                      onClick={() => setShowNotebookCreator(false)}
                      className="px-2.5 py-1 text-[11px] font-semibold text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 rounded"
                    >
                      {T.btnCancel}
                    </button>
                    <button
                      type="submit"
                      className="px-3  py-1 text-[11px] font-bold bg-indigo-600 hover:bg-indigo-700 text-white rounded"
                    >
                      {T.btnSaveNb}
                    </button>
                  </div>
                </form>
              )}

              {/* Notebook selector buttons list */}
              <div className="space-y-1">
                <button
                  onClick={() => setActiveNotebook("all")}
                  className={`w-full text-left px-3 py-2.5 rounded-xl text-xs font-semibold flex items-center justify-between transition-all ${
                    activeNotebook === "all"
                      ? "bg-indigo-600 text-white"
                      : "bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-350 hover:bg-slate-100 dark:hover:bg-slate-850"
                  }`}
                >
                  <span className="flex items-center gap-2">
                    <Layers className="w-3.5 h-3.5" />
                    {T.filterAllBooks}
                  </span>
                  <span className={`text-[10px] px-2 py-0.5 rounded-full ${activeNotebook === "all" ? "bg-white/20 text-white" : "bg-slate-200 dark:bg-slate-800 text-slate-655"}`}>
                    {words.length}
                  </span>
                </button>

                {notebooks.map((nb) => {
                  const numWords = words.filter((w) => w.notebookId === nb.id).length;
                  return (
                    <button
                      key={nb.id}
                      onClick={() => setActiveNotebook(nb.id)}
                      className={`w-full text-left px-3 py-2.5 rounded-xl text-xs font-semibold flex items-center justify-between transition-all ${
                        activeNotebook === nb.id
                          ? "bg-indigo-600 text-white"
                          : "bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-350 hover:bg-slate-100 dark:hover:bg-slate-850"
                      }`}
                    >
                      <span className="truncate pr-2">
                        🔖 {nb.name}
                      </span>
                      <span className={`text-[10px] px-2 py-0.5 rounded-full ${activeNotebook === nb.id ? "bg-white/20 text-white" : "bg-slate-200 dark:bg-slate-800 text-slate-655"}`}>
                        {numWords}
                      </span>
                    </button>
                  );
                })}
              </div>
            </div>
          </div>
        </div>
      </main>

      {/* Floating Add Word dialog block */}
      <AddWordModal
        isOpen={isAddOpen}
        onClose={() => setIsAddOpen(false)}
        notebooks={notebooks}
        defaultNotebookId={notebooks[0]?.id || "notebook-default"}
        lang={lang}
        onWordAdded={() => {
          reloadWords();
        }}
      />
    </div>
  );
}
